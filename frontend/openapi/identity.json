{
  "components": {
    "schemas": {
      "EndpointsIdentitiesLoginRequest": {
        "properties": {
          "email": {
            "format": "email",
            "maxLength": 320,
            "minLength": 0,
            "pattern": "^[^@]+@[^@]+$",
            "type": "string"
          },
          "password": {
            "maxLength": 128,
            "minLength": 0,
            "type": "string"
          }
        },
        "required": [
          "email",
          "password"
        ],
        "type": "object"
      },
      "EndpointsIdentitiesLoginResponse": {
        "properties": {
          "accessToken": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "expiresAt": {
            "format": "date-time",
            "type": "string"
          },
          "id": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "FastEndpointsProblemDetails": {
        "description": "RFC9457 compatible problem details/ error response class. this can be used by configuring startup like so:\n```app.UseFastEndpoints(c =&gt; c.Errors.UseProblemDetails())```",
        "properties": {
          "detail": {
            "description": "the details of the error",
            "type": [
              "null",
              "string"
            ]
          },
          "errors": {
            "items": {
              "description": "the error details object",
              "properties": {
                "code": {
                  "description": "the code of the error",
                  "type": [
                    "null",
                    "string"
                  ]
                },
                "name": {
                  "default": "Error or field name",
                  "description": "the name of the error or property of the dto that caused the error",
                  "type": "string"
                },
                "reason": {
                  "default": "Error reason",
                  "description": "the reason for the error",
                  "type": "string"
                },
                "severity": {
                  "description": "the severity of the error",
                  "type": [
                    "null",
                    "string"
                  ]
                }
              },
              "type": "object"
            },
            "type": "array"
          },
          "instance": {
            "default": "/api/route",
            "type": "string"
          },
          "status": {
            "default": 400,
            "format": "int32",
            "type": "integer"
          },
          "title": {
            "default": "One or more validation errors occurred.",
            "type": [
              "null",
              "string"
            ]
          },
          "traceId": {
            "default": "0HMPNHL0JHL76:00000001",
            "type": "string"
          },
          "type": {
            "default": "https://www.rfc-editor.org/rfc/rfc7231#section-6.5.1",
            "type": [
              "null",
              "string"
            ]
          }
        },
        "type": "object"
      },
      "IdentitiesRegisterRequest": {
        "properties": {
          "email": {
            "format": "email",
            "maxLength": 320,
            "minLength": 0,
            "pattern": "^[^@]+@[^@]+$",
            "type": "string"
          },
          "password": {
            "maxLength": 128,
            "minLength": 12,
            "type": "string"
          }
        },
        "required": [
          "email",
          "password"
        ],
        "type": "object"
      },
      "IdentitiesResendVerificationRequest": {
        "properties": {
          "email": {
            "format": "email",
            "maxLength": 320,
            "minLength": 0,
            "pattern": "^[^@]+@[^@]+$",
            "type": "string"
          }
        },
        "required": [
          "email"
        ],
        "type": "object"
      }
    },
    "securitySchemes": {
      "JWTBearerAuth": {
        "bearerFormat": "JWT",
        "description": "Enter a JWT token to authorize the requests...",
        "scheme": "Bearer",
        "type": "http"
      }
    }
  },
  "info": {
    "title": "Services.UserIdentity | v1",
    "version": "v1"
  },
  "openapi": "3.1.1",
  "paths": {
    "/identities/login": {
      "post": {
        "operationId": "EndpointsIdentitiesLoginEndpoint",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EndpointsIdentitiesLoginRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EndpointsIdentitiesLoginResponse"
                }
              }
            },
            "description": "Success"
          },
          "400": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/FastEndpointsProblemDetails"
                }
              }
            },
            "description": "Bad Request"
          }
        },
        "tags": [
          "Identities"
        ]
      }
    },
    "/identities/register": {
      "post": {
        "operationId": "IdentitiesRegisterEndpoint",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/IdentitiesRegisterRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "type": "string"
                }
              }
            },
            "description": "Success"
          },
          "400": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/FastEndpointsProblemDetails"
                }
              }
            },
            "description": "Bad Request"
          }
        },
        "tags": [
          "Identities"
        ]
      }
    },
    "/identities/resend-verification": {
      "post": {
        "operationId": "IdentitiesResendVerificationEndpoint",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/IdentitiesResendVerificationRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "type": "string"
                }
              }
            },
            "description": "Success"
          },
          "400": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/FastEndpointsProblemDetails"
                }
              }
            },
            "description": "Bad Request"
          }
        },
        "tags": [
          "Identities"
        ]
      }
    },
    "/identities/verify/{verificationCode}": {
      "get": {
        "operationId": "IdentitiesVerifyEndpoint",
        "parameters": [
          {
            "in": "path",
            "name": "verificationCode",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "type": "string"
                }
              }
            },
            "description": "Success"
          }
        },
        "tags": [
          "Identities"
        ]
      }
    }
  }
}
