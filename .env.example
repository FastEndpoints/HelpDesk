DOMAIN=helpdesk.example.com

# Use only URI-unreserved characters (A-Z, a-z, 0-9, ., _, ~, -).
# deploy-init.sh generates hexadecimal values.
MONGO_INITDB_ROOT_USERNAME=helpdesk
MONGO_INITDB_ROOT_PASSWORD=replace-with-a-long-random-password

# Matching production-only PKCS#1 DER values, base64 encoded on one line.
JWT_PRIVATE_KEY=replace-with-base64-private-key
JWT_PUBLIC_KEY=replace-with-base64-public-key

SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USE_SSL=true
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_SENDER_NAME=HelpDesk
SMTP_SENDER_EMAIL=
SMTP_ADMIN_NAME=HelpDesk Admin
SMTP_ADMIN_EMAIL=
