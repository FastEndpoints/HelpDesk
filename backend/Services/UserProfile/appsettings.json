{
  "UserProfile": {
    "DatabaseName": "HelpDesk_UserProfile",
    "Jwt": {
      "Issuer": "HelpDesk.UserIdentity",
      "Audience": "HelpDesk.Services",
      "PublicKey": ""
    },
    "ProfilePictures": {
      "StorageRoot": "data/profile-pictures",
      "PublicBaseUrl": "",
